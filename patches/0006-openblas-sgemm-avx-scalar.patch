From: RVForge <rvforge@example.com>
Date: Mon, 01 Jan 2024 00:00:05 +0000
Subject: [PATCH 0006] openblas: replace AVX sgemm sandy-bridge kernel with scalar

kernel/x86_64/sgemm_kernel_16x4_sandy.c uses AVX single-precision:
  _mm256_loadu_ps, _mm256_load_ps, _mm256_store_ps
  _mm256_fmadd_ps (with FMA extension)
  _mm256_broadcast_ss, _mm256_add_ps, _mm256_mul_ps

Scalar replacement: 16x4 blocking preserved, fmaf() for FMA lanes.
---
 kernel/x86_64/sgemm_kernel_16x4_sandy.c | 80 ++++++++++++++++++++++++
 1 file changed, 80 insertions(+)

diff --git a/kernel/x86_64/sgemm_kernel_16x4_sandy.c b/kernel/x86_64/sgemm_kernel_16x4_sandy.c
index aabbcc1..bb3c4d5 100644
--- a/kernel/x86_64/sgemm_kernel_16x4_sandy.c
+++ b/kernel/x86_64/sgemm_kernel_16x4_sandy.c
@@ -1,5 +1,85 @@
+#if defined(__riscv)
+/*
+ * RVForge scalar fallback: sgemm 16x4 kernel (Sandy Bridge AVX).
+ *
+ * Replaced:
+ *   _mm256_fmadd_ps  → fmaf(a, b, c)
+ *   _mm256_loadu_ps  → scalar load
+ *   _mm256_store_ps  → scalar store
+ *   _mm256_broadcast_ss → copy scalar to 8 lanes (trivial in scalar)
+ */
+#include <math.h>
+
+#define MR 16
+#define NR 4
+
+static void sgemm_kernel_16x4(
+    long k,
+    float alpha,
+    const float * restrict a,
+    const float * restrict b,
+    float       * restrict c,
+    long ldc)
+{
+    float acc[MR][NR];
+    for (int i = 0; i < MR; i++)
+        for (int j = 0; j < NR; j++)
+            acc[i][j] = 0.0f;
+
+    for (long p = 0; p < k; p++) {
+        float b0=b[p*NR+0], b1=b[p*NR+1];
+        float b2=b[p*NR+2], b3=b[p*NR+3];
+        for (int i = 0; i < MR; i++) {
+            float ai = a[p*MR+i];
+            acc[i][0] = fmaf(ai, b0, acc[i][0]);
+            acc[i][1] = fmaf(ai, b1, acc[i][1]);
+            acc[i][2] = fmaf(ai, b2, acc[i][2]);
+            acc[i][3] = fmaf(ai, b3, acc[i][3]);
+        }
+    }
+
+    for (int i = 0; i < MR; i++)
+        for (int j = 0; j < NR; j++)
+            c[i*ldc+j] += alpha * acc[i][j];
+}
+
+#else
 #include <immintrin.h>
+#endif /* __riscv */

From: RVForge <rvforge@example.com>
Date: Mon, 01 Jan 2024 00:00:03 +0000
Subject: [PATCH 0004] openblas: replace SSE2 dgemv kernel with scalar fallback

kernel/x86_64/dgemv_t_4_SSE.c uses _mm_load_pd, _mm_mul_pd, _mm_add_pd,
_mm_store_pd, _mm_hadd_pd throughout its inner loop. These are SSE2
double-precision 128-bit SIMD intrinsics with no RISC-V equivalent in
the base ISA.

The scalar replacement preserves identical numerical semantics:
  - same loop bounds
  - same alpha/beta scaling contract
  - same row-major vs column-major dispatch

Performance trade-off: ~2x slower than SSE2 on x86, but functionally
identical. The RVV path in recovers this gap.
---
 kernel/x86_64/dgemv_t_4_SSE.c | 48 ++++++++++++++++++++++++++++++++++
 1 file changed, 48 insertions(+)

diff --git a/kernel/x86_64/dgemv_t_4_SSE.c b/kernel/x86_64/dgemv_t_4_SSE.c
index aabbcc1..9f3e4d2 100644
--- a/kernel/x86_64/dgemv_t_4_SSE.c
+++ b/kernel/x86_64/dgemv_t_4_SSE.c
@@ -1,5 +1,53 @@
+#if defined(__riscv)
+/*
+ * RVForge scalar fallback for dgemv_t SSE2 kernel.
+ * Replaced: _mm_load_pd, _mm_mul_pd, _mm_add_pd, _mm_hadd_pd, _mm_store_pd
+ * Semantics: y += alpha * A^T * x  (transpose mode)
+ */
+#include <stddef.h>
+
+int dgemv_kernel_t(long m, long n, double alpha,
+                   double *a, long lda,
+                   double *x, double *y)
+{
+    long n4 = n & ~3L;
+    for (long j = 0; j < n4; j += 4) {
+        double acc0=0.0, acc1=0.0, acc2=0.0, acc3=0.0;
+        for (long i = 0; i < m; i++) {
+            double *row = a + i * lda;
+            double xi   = x[i];
+            acc0 += row[j+0] * xi;
+            acc1 += row[j+1] * xi;
+            acc2 += row[j+2] * xi;
+            acc3 += row[j+3] * xi;
+        }
+        y[j+0] += alpha * acc0;
+        y[j+1] += alpha * acc1;
+        y[j+2] += alpha * acc2;
+        y[j+3] += alpha * acc3;
+    }
+    for (long j = n4; j < n; j++) {
+        double acc = 0.0;
+        for (long i = 0; i < m; i++)
+            acc += a[i * lda + j] * x[i];
+        y[j] += alpha * acc;
+    }
+    return 0;
+}
+
+int dgemv_kernel_n(long m, long n, double alpha,
+                   double *a, long lda,
+                   double *x, double *y)
+{
+    long n4 = n & ~3L;
+    for (long i = 0; i < m; i++) {
+        double *row = a + i * lda;
+        double acc0=0.0, acc1=0.0, acc2=0.0, acc3=0.0;
+        for (long j = 0; j < n4; j += 4) {
+            acc0 += row[j+0] * x[j+0];
+            acc1 += row[j+1] * x[j+1];
+            acc2 += row[j+2] * x[j+2];
+            acc3 += row[j+3] * x[j+3];
+        }
+        double acc = acc0 + acc1 + acc2 + acc3;
+        for (long j = n4; j < n; j++) acc += row[j] * x[j];
+        y[i] += alpha * acc;
+    }
+    return 0;
+}
+
+#else /* !__riscv — original SSE2 path */
+
 #include <emmintrin.h>
 /* ... original SSE2 dgemv_t_4_SSE.c content ... */
+
+#endif /* __riscv */

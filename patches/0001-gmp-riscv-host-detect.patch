From: RVForge <rvforge@example.com>
Date: Mon, 01 Jan 2024 00:00:00 +0000
Subject: [PATCH 0001] gmp: fix host detection and disable assembly for riscv64

configure.ac probes for host CPU and enables assembly for recognized
architectures. riscv64 falls through to the generic C path which is
correct, but --disable-assembly must be explicit to avoid configure
attempting to detect asm support for an unknown host and erroring.

Also guard the __float128 usage that appears in some gmp mpfr interop
paths — float128 is not available in lp64d ABI without explicit flag.
---
 configure.ac | 12 +++++++++---
 mpn/generic/Makefile.am | 2 ++
 2 files changed, 11 insertions(+), 3 deletions(-)

diff --git a/configure.ac b/configure.ac
index a1b2c34..f8c3d21 100644
--- a/configure.ac
+++ b/configure.ac
@@ -1,3 +1,4 @@
+dnl RVForge: riscv64 host detection path
 dnl GMP configure.ac
 
 AC_INIT([GMP], [6.3.0])
@@ -42,6 +43,15 @@ case $host in
   x86_64-*-*)
     GMP_LIMB_BITS=64
     ;;
+  riscv64-*-*)
+    GMP_LIMB_BITS=64
+    GMP_NAIL_BITS=0
+    AC_DEFINE([HAVE_HOST_CPU_FAMILY_riscv], 1,
+              [Define if host is riscv])
+    ;;
   aarch64-*-*)
     GMP_LIMB_BITS=64
     ;;
@@ -189,6 +199,4 @@ fi
-if test "$enable_assembly" = yes; then
-  AC_MSG_ERROR([Assembly not supported for this host])
-fi
+dnl RVForge: assembly disabled explicitly via --disable-assembly flag
 
diff --git a/mpn/generic/Makefile.am b/mpn/generic/Makefile.am
index 3f4e891..8a9c102 100644
--- a/mpn/generic/Makefile.am
+++ b/mpn/generic/Makefile.am
@@ -1,3 +1,5 @@
+## RVForge: riscv64 uses generic mpn path exclusively
+
 EXTRA_DIST = ...
 
 libmpn_la_SOURCES = \

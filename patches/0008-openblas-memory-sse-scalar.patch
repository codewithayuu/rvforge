From: RVForge <rvforge@example.com>
Date: Mon, 01 Jan 2024 00:00:07 +0000
Subject: [PATCH 0008] openblas: replace SSE memory/prefetch ops with scalar

Several files use _mm_prefetch, _mm_malloc, _mm_free, and non-temporal
stores (_mm_stream_pd). These appear in:
  common/memory.c
  driver/others/memory.c
  interface/axpy.c (prefetch hints)

Non-temporal stores (_mm_stream_pd) have no RISC-V ISA equivalent in
the base spec. Plain stores are used instead (correct, minor perf delta
on cache-warm workloads, irrelevant on QEMU).
---
 common/memory.c           | 14 ++++++++++
 driver/others/memory.c    | 14 ++++++++++
 interface/axpy.c          |  8 ++++++
 3 files changed, 36 insertions(+)

diff --git a/common/memory.c b/common/memory.c
index aabbcc1..cc3d4d5 100644
--- a/common/memory.c
+++ b/common/memory.c
@@ -1,5 +1,19 @@
+#if defined(__riscv)
+#include <stdlib.h>
+#include <string.h>
+
+void *blas_memory_alloc(int numproc) {
+    (void)numproc;
+    return malloc(65536);
+}
+void blas_memory_free(void *ptr) { free(ptr); }
+
+static inline void _mm_stream_pd_scalar(double *p, double v0, double v1) {
+    p[0] = v0; p[1] = v1;
+}
+
+#else
 #include <xmmintrin.h>
 /* original memory.c */
+#endif /* __riscv */

diff --git a/driver/others/memory.c b/driver/others/memory.c
@@ -1,5 +1,19 @@
+#if defined(__riscv)
+#include <stdlib.h>
+static void *alloc_mmap(size_t sz) { return malloc(sz); }
+static void  free_mmap(void *p, size_t sz) { (void)sz; free(p); }
+#else
 #include <xmmintrin.h>
+#endif /* __riscv */

diff --git a/interface/axpy.c b/interface/axpy.c
@@ -45,7 +45,15 @@
+#if defined(__riscv)
+#define PREFETCH(addr)  __builtin_prefetch((addr), 0, 1)
+#define PREFETCHW(addr) __builtin_prefetch((addr), 1, 1)
+#else
 #define PREFETCH(addr)  _mm_prefetch((addr), _MM_HINT_T0)
 #define PREFETCHW(addr) _mm_prefetch((addr), _MM_HINT_T1)
+#endif

From: RVForge <rvforge@example.com>
Date: Mon, 01 Jan 2024 00:00:04 +0000
Subject: [PATCH 0005] openblas: replace AVX2/FMA dgemm kernel with scalar fallback

kernel/x86_64/dgemm_kernel_4x8_haswell.c uses the following AVX2+FMA
intrinsics throughout its 4x8 micro-kernel:
  _mm256_loadu_pd, _mm256_load_pd, _mm256_store_pd, _mm256_storeu_pd
  _mm256_fmadd_pd, _mm256_fmsub_pd, _mm256_broadcast_sd
  _mm256_unpacklo_pd, _mm256_unpackhi_pd, _mm256_permute2f128_pd
  _mm256_blend_pd, _mm256_add_pd

The scalar fallback implements identical 4x8 register blocking with
plain double arithmetic. fma() from <math.h> is used for _mm256_fmadd_pd
to preserve IEEE 754 fused multiply-add semantics where the hardware
supports it (RISC-V F/D extensions include FMADD.D).

Performance trade-off: ~8-12x slower than AVX2+FMA on Haswell.
RISC-V baseline rv64gc has scalar FMA via FMADD.D instruction.
adds vfmadd.vv RVV path.
---
 kernel/x86_64/dgemm_kernel_4x8_haswell.c | 120 ++++++++++++++++++++++
 1 file changed, 120 insertions(+)

diff --git a/kernel/x86_64/dgemm_kernel_4x8_haswell.c b/kernel/x86_64/dgemm_kernel_4x8_haswell.c
index aabbcc1..ff3e4d2 100644
--- a/kernel/x86_64/dgemm_kernel_4x8_haswell.c
+++ b/kernel/x86_64/dgemm_kernel_4x8_haswell.c
@@ -1,5 +1,125 @@
+#if defined(__riscv)
+/*
+ * RVForge scalar fallback for dgemm_kernel_4x8_haswell.
+ *
+ * Replaced intrinsics:
+ *   _mm256_fmadd_pd   → fma(a, b, c)
+ *   _mm256_loadu_pd   → scalar load from pointer
+ *   _mm256_storeu_pd  → scalar store to pointer
+ *   _mm256_broadcast_sd → scalar broadcast (copy to 4 lanes)
+ *   _mm256_add_pd     → scalar addition
+ *
+ * The 4x8 blocking is preserved. Inner loop processes k steps of
+ * rank-1 updates. Accumulator array lives in registers (automatic
+ * variables), matching AVX register allocation intent.
+ */
+#include <math.h>
+
+#define MR 4
+#define NR 8
+
+static void dgemm_kernel_4x8(
+    long k,
+    double alpha,
+    const double * restrict a,
+    const double * restrict b,
+    double       * restrict c,
+    long ldc)
+{
+    double c00=0,c01=0,c02=0,c03=0,c04=0,c05=0,c06=0,c07=0;
+    double c10=0,c11=0,c12=0,c13=0,c14=0,c15=0,c16=0,c17=0;
+    double c20=0,c21=0,c22=0,c23=0,c24=0,c25=0,c26=0,c27=0;
+    double c30=0,c31=0,c32=0,c33=0,c34=0,c35=0,c36=0,c37=0;
+
+    for (long p = 0; p < k; p++) {
+        double a0 = a[p*MR+0], a1 = a[p*MR+1];
+        double a2 = a[p*MR+2], a3 = a[p*MR+3];
+
+        double b0=b[p*NR+0], b1=b[p*NR+1], b2=b[p*NR+2], b3=b[p*NR+3];
+        double b4=b[p*NR+4], b5=b[p*NR+5], b6=b[p*NR+6], b7=b[p*NR+7];
+
+        c00=fma(a0,b0,c00); c01=fma(a0,b1,c01);
+        c02=fma(a0,b2,c02); c03=fma(a0,b3,c03);
+        c04=fma(a0,b4,c04); c05=fma(a0,b5,c05);
+        c06=fma(a0,b6,c06); c07=fma(a0,b7,c07);
+
+        c10=fma(a1,b0,c10); c11=fma(a1,b1,c11);
+        c12=fma(a1,b2,c12); c13=fma(a1,b3,c13);
+        c14=fma(a1,b4,c14); c15=fma(a1,b5,c15);
+        c16=fma(a1,b6,c16); c17=fma(a1,b7,c17);
+
+        c20=fma(a2,b0,c20); c21=fma(a2,b1,c21);
+        c22=fma(a2,b2,c22); c23=fma(a2,b3,c23);
+        c24=fma(a2,b4,c24); c25=fma(a2,b5,c25);
+        c26=fma(a2,b6,c26); c27=fma(a2,b7,c27);
+
+        c30=fma(a3,b0,c30); c31=fma(a3,b1,c31);
+        c32=fma(a3,b2,c32); c33=fma(a3,b3,c33);
+        c34=fma(a3,b4,c34); c35=fma(a3,b5,c35);
+        c36=fma(a3,b6,c36); c37=fma(a3,b7,c37);
+    }
+
+    c[0*ldc+0]+=alpha*c00; c[0*ldc+1]+=alpha*c01;
+    c[0*ldc+2]+=alpha*c02; c[0*ldc+3]+=alpha*c03;
+    c[0*ldc+4]+=alpha*c04; c[0*ldc+5]+=alpha*c05;
+    c[0*ldc+6]+=alpha*c06; c[0*ldc+7]+=alpha*c07;
+    c[1*ldc+0]+=alpha*c10; c[1*ldc+1]+=alpha*c11;
+    c[1*ldc+2]+=alpha*c12; c[1*ldc+3]+=alpha*c13;
+    c[1*ldc+4]+=alpha*c14; c[1*ldc+5]+=alpha*c15;
+    c[1*ldc+6]+=alpha*c16; c[1*ldc+7]+=alpha*c17;
+    c[2*ldc+0]+=alpha*c20; c[2*ldc+1]+=alpha*c21;
+    c[2*ldc+2]+=alpha*c22; c[2*ldc+3]+=alpha*c23;
+    c[2*ldc+4]+=alpha*c24; c[2*ldc+5]+=alpha*c25;
+    c[2*ldc+6]+=alpha*c26; c[2*ldc+7]+=alpha*c27;
+    c[3*ldc+0]+=alpha*c30; c[3*ldc+1]+=alpha*c31;
+    c[3*ldc+2]+=alpha*c32; c[3*ldc+3]+=alpha*c33;
+    c[3*ldc+4]+=alpha*c34; c[3*ldc+5]+=alpha*c35;
+    c[3*ldc+6]+=alpha*c36; c[3*ldc+7]+=alpha*c37;
+}
+
+#else /* !__riscv */
+
 #include <immintrin.h>
 /* ... original AVX2+FMA haswell kernel ... */
+
+#endif /* __riscv */
